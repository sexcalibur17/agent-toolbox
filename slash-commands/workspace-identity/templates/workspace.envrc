# Template: <workspace>/.envrc
# Copy to a workspace root, fill NAME/EMAIL, then: direnv allow <workspace>
# Self-locating: resolves its own directory, so no path is tied to a fixed workspaces root.
# Any repo nested under the workspace inherits this identity.

ws="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

git_identity "NAME" "EMAIL"                                          # helper from ~/.config/direnv/direnvrc
export GH_CONFIG_DIR="$ws/dotfiles/gh"                               # isolates gh account/token
export GIT_SSH_COMMAND="ssh -i $ws/dotfiles/ssh/id_ed25519 -o IdentitiesOnly=yes"
