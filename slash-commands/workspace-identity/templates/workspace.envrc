# Template: <workspace>/.envrc — OPTIONAL gh account isolation (needs direnv).
# Copy to a workspace root, then: direnv allow <workspace>
#
# NOTE: git identity + SSH key do NOT live here — they're in dotfiles/git/config,
# wired via ~/.gitconfig includeIf, so they work in GUIs too. This file only isolates
# the gh CLI account/token, which has no git-config equivalent. Self-locating.
export GH_CONFIG_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/dotfiles/gh"
